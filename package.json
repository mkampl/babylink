{
  "name": "babylink-webrtc",
  "version": "1.0.0",
  "description": "WebRTC Baby Monitor with voice activation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t babylink .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "simulate:esp32": "node tools/esp32-simulator.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run tests/e2e-server/smoke.test.js",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:full": "vitest run",
    "test:gate": "vitest run --reporter=verbose"
  },
  "keywords": [
    "webrtc",
    "baby-monitor",
    "socket.io",
    "voice-activation",
    "pwa"
  ],
  "author": "Markus Kampl",
  "license": "BSD-3-Clause",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "socket.io": "^4.7.2",
    "winston": "^3.11.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
