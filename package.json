{
  "name": "babylink-webrtc",
  "version": "1.0.0",
  "description": "WebRTC Baby Monitor with voice activation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t babylink .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart"
  },
  "keywords": ["webrtc", "baby-monitor", "socket.io", "voice-activation", "pwa"],
  "author": "Markus Kampl",
  "license": "BSD-3-Clause",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
