# BabyLink Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=production
PORT=3001

# WebRTC Configuration
# STUN server for NAT traversal
STUN_SERVER=stun:stun.l.google.com:19302
# Optional TURN server for difficult network scenarios
# TURN_SERVER=turn:turn.example.com:3478
# TURN_USERNAME=username
# TURN_PASSWORD=password

# Room Configuration
MAX_ROOMS=1000
MAX_BABIES_PER_ROOM=5
MAX_PARENTS_PER_ROOM=10
ROOM_CLEANUP_INTERVAL=3600000  # 1 hour in milliseconds

# Security Configuration
RATE_LIMIT_WINDOW=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info  # Options: error, warn, info, debug
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/babylink.log

# Redis Configuration (optional, for persistence and scaling)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# CORS Configuration (optional, for specific origins)
# CORS_ORIGIN=https://yourdomain.com
# CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=change-this-to-a-random-secret-in-production

# Feature Flags
ENABLE_MULTI_BABY=true
ENABLE_RECORDING=false
ENABLE_NOTIFICATIONS=false
