# .gitignore

# Dependencies
node_modules/
babylink-env/

# Environment variables
.env
.env.local
.env.*.local

# SSL certificates (never commit these!)
*.pem
*.key
*.crt
*.cert
ssl/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Docker
docker-compose.override.yml

# Temporary files
tmp/
temp/
